{
  "expo": {
    "name": "Clear HiiT",
    "slug": "hiit-timer",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/hiit-icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "deploymentTarget": "16.4",
      "bundleIdentifier": "com.georgefromgib.hiittimer",
      "buildNumber": "6",
      "appleTeamId": "KM666T7T27",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ],
        "CFBundleLocalizations": ["en", "es", "fr"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.georgefromgib.hiittimer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "plugins": [
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "image": "./assets/hiit-splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 400
        }
      ],
      "expo-asset",
      "expo-iap",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "b088a50f-b0f1-4ed6-810b-092b1cb02360"
      }
    },
    "owner": "georgefromgib"
  }
}
