{
  "expo": {
    "name": "Clear HiiT",
    "slug": "clear-hiit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/hiit-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": {
        "any": "./assets/hiit-icon.png",
        "dark": "./assets/hiit-icon-dark.png",
        "tinted": "./assets/hiit-icon-tinted.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.georgefromgib.hiittimer",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.georgefromgib.hiittimer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "plugins": [
      "expo-audio",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "b088a50f-b0f1-4ed6-810b-092b1cb02360"
      }
    }
  }
}
